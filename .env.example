# Omnipin deployment secrets. Copy to `.env` and fill in.
# `.env` is gitignored — never commit real keys.

# --- IPFS provider (Filecoin) ---

# Filecoin: private key of a wallet funded with FIL (gas) + USDfc (storage).
# Generate one with `cast wallet new`, then fund ~0.1 FIL + ~$1 USDfc.
# Test for free first with `--filecoin-chain=calibration` + faucets.
# For redundancy you can add more providers (e.g. Pinata, Lighthouse) to the
# --providers flag and their tokens here — not required, Filecoin persists alone.
OMNIPIN_FILECOIN_TOKEN=0x...

# ENS is updated manually, not by Omnipin: `pnpm deploy` prints a Root CID,
# which you paste as `ipfs://<CID>` into the Content Hash record on
# app.ens.domains. The ses.eth key never leaves your wallet.
